# .env.example
# -----------------------------------------------------------------------------
# This is a TEMPLATE for your environment variables (secret settings).
#
# HOW TO USE THIS FILE:
#   1. Make a copy of this file and name the copy ".env.local"
#   2. Open ".env.local" and paste your real Anthropic API key after the "="
#   3. Save the file. Never share or commit ".env.local" — it holds your secret.
#
# Where do I get an API key? See the README, section "How to set it up".

# Your Anthropic (Claude) API key. It always starts with "sk-ant-".
ANTHROPIC_API_KEY=sk-ant-your-key-here
